@incollection{yousmanTextImageMedia2016,
  title = {The {{Text}} and the {{Image}}: {{Media Literacy}}, {{Pedagogy}}, and {{Generational Divides}}},
  author = {Yousman, Bill and Frechette, Julie and Williams, Rob},
  year = 2016,
  edition = {1},
  pages = {157--170},
  publisher = {Routledge},
  doi = {10.4324/9781315682372-15},
  abstract = {This chapter reveals traditional classroom films are not really VISUAL in a way that captivates students. Visual images cannot provide the effective pedagogy people strive for if they are asked to stand all on their own. Muller argues that visual communication and textual communication follow a different logic: while textual communication is based on argumentation, visual communication is based on association. This cultural divide is one key reason why students often have difficulty making the shift from emotional to intellectual engagement. It causes the issue of speed working against in-depth understanding. Media literacy education offers a bridge across the cultural divide between text-based faculty and image-based students. Photography allows people to uncritically think that photographs provide a magic path to the truth. Since the advent of photography, followed by film and television, and now digital mobile technologies, people have become more and more of an image-based culture.},
  isbn = {1-138-92766-X}
}
